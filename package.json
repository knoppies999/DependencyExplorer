{
  "name": "dependency-explorer",
  "displayName": "Dependency Explorer",
  "description": "Full dependency tree (including transitive dependencies) for npm, pnpm and NuGet projects, with vulnerability flags and one-click update, transitive override, or bulk fix.",
  "version": "1.2.0",
  "publisher": "RuanduPlessis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/knoppies999/DependencyExplorer.git"
  },
  "bugs": {
    "url": "https://github.com/knoppies999/DependencyExplorer/issues"
  },
  "homepage": "https://github.com/knoppies999/DependencyExplorer#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "dependencies",
    "transitive dependencies",
    "vulnerabilities",
    "npm",
    "pnpm",
    "nuget"
  ],
  "main": "./out/extension.js",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#3A2F8F",
    "theme": "dark"
  },
  "contributes": {
    "configuration": {
      "title": "Dependency Explorer",
      "properties": {
        "dependencyExplorer.alwaysLatestPackages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Packages that should always be bumped to their **latest** published version during any upgrade — both **Fix All Vulnerabilities** and **Update All Packages to Latest**. Names are matched case-insensitively, and `*` is a wildcard (e.g. `@myorg/*` matches every package in that scope). Add a package quickly with **Always Update to Latest Version** in a dependency's right-click menu."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dependencyExplorer",
          "title": "Dependencies",
          "icon": "media/dependencies.svg"
        }
      ]
    },
    "views": {
      "dependencyExplorer": [
        {
          "id": "dependencyExplorer.tree",
          "name": "Dependencies",
          "icon": "media/dependencies.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "dependencyExplorer.tree",
        "contents": "No npm, pnpm or NuGet projects found in this workspace.\nnpm/pnpm projects need a package-lock.json or pnpm-lock.yaml (run npm install / pnpm install).\nNuGet projects need obj/project.assets.json (run dotnet restore).\n[Refresh](command:dependencyExplorer.refresh)"
      }
    ],
    "commands": [
      {
        "command": "dependencyExplorer.refresh",
        "title": "Refresh",
        "category": "Dependency Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "dependencyExplorer.fixAcrossProjects",
        "title": "Update Package Across All Projects…",
        "category": "Dependency Explorer",
        "icon": "$(replace-all)"
      },
      {
        "command": "dependencyExplorer.fixAllVulnerabilities",
        "title": "Fix All Vulnerabilities…",
        "category": "Dependency Explorer",
        "icon": "$(shield)"
      },
      {
        "command": "dependencyExplorer.fixProjectVulnerabilities",
        "title": "Fix Vulnerabilities in This Project…",
        "category": "Dependency Explorer",
        "icon": "$(shield)"
      },
      {
        "command": "dependencyExplorer.updateAllToLatest",
        "title": "Update All Packages to Latest…",
        "category": "Dependency Explorer",
        "icon": "$(arrow-circle-up)"
      },
      {
        "command": "dependencyExplorer.updateProjectToLatest",
        "title": "Update All Packages in This Project to Latest…",
        "category": "Dependency Explorer",
        "icon": "$(arrow-circle-up)"
      },
      {
        "command": "dependencyExplorer.addToAlwaysLatest",
        "title": "Always Update to Latest Version",
        "category": "Dependency Explorer",
        "icon": "$(star)"
      },
      {
        "command": "dependencyExplorer.updateDependency",
        "title": "Update Version…",
        "category": "Dependency Explorer",
        "icon": "$(arrow-up)"
      },
      {
        "command": "dependencyExplorer.overrideDependency",
        "title": "Override / Pin Version…",
        "category": "Dependency Explorer",
        "icon": "$(pin)"
      },
      {
        "command": "dependencyExplorer.openManifest",
        "title": "Open Manifest",
        "category": "Dependency Explorer",
        "icon": "$(go-to-file)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "dependencyExplorer.updateDependency",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.overrideDependency",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.openManifest",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.fixProjectVulnerabilities",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.updateProjectToLatest",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.addToAlwaysLatest",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "dependencyExplorer.fixAllVulnerabilities",
          "when": "view == dependencyExplorer.tree",
          "group": "navigation@1"
        },
        {
          "command": "dependencyExplorer.updateAllToLatest",
          "when": "view == dependencyExplorer.tree",
          "group": "navigation@2"
        },
        {
          "command": "dependencyExplorer.fixAcrossProjects",
          "when": "view == dependencyExplorer.tree",
          "group": "navigation@3"
        },
        {
          "command": "dependencyExplorer.refresh",
          "when": "view == dependencyExplorer.tree",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "dependencyExplorer.updateDependency",
          "when": "view == dependencyExplorer.tree && viewItem == dep:direct",
          "group": "inline@1"
        },
        {
          "command": "dependencyExplorer.overrideDependency",
          "when": "view == dependencyExplorer.tree && viewItem == dep:transitive",
          "group": "inline@1"
        },
        {
          "command": "dependencyExplorer.updateDependency",
          "when": "view == dependencyExplorer.tree && viewItem == dep:direct"
        },
        {
          "command": "dependencyExplorer.overrideDependency",
          "when": "view == dependencyExplorer.tree && viewItem == dep:transitive"
        },
        {
          "command": "dependencyExplorer.addToAlwaysLatest",
          "when": "view == dependencyExplorer.tree && (viewItem == dep:direct || viewItem == dep:transitive)",
          "group": "1_modify@2"
        },
        {
          "command": "dependencyExplorer.fixProjectVulnerabilities",
          "when": "view == dependencyExplorer.tree && viewItem == project",
          "group": "inline@1"
        },
        {
          "command": "dependencyExplorer.fixProjectVulnerabilities",
          "when": "view == dependencyExplorer.tree && viewItem == project"
        },
        {
          "command": "dependencyExplorer.updateProjectToLatest",
          "when": "view == dependencyExplorer.tree && viewItem == project"
        },
        {
          "command": "dependencyExplorer.openManifest",
          "when": "view == dependencyExplorer.tree && viewItem == project"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.5.0"
  }
}
