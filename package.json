{
  "name": "dependency-explorer",
  "displayName": "Dependency Explorer",
  "description": "Full dependency tree (including transitive dependencies) for npm, pnpm and NuGet projects, with vulnerability flags and one-click update, transitive override, or bulk fix.",
  "version": "1.6.1",
  "publisher": "RuanduPlessis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/knoppies999/DependencyExplorer.git"
  },
  "bugs": {
    "url": "https://github.com/knoppies999/DependencyExplorer/issues"
  },
  "homepage": "https://github.com/knoppies999/DependencyExplorer#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "dependencies",
    "transitive dependencies",
    "vulnerabilities",
    "npm",
    "pnpm",
    "nuget"
  ],
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#3A2F8F",
    "theme": "dark"
  },
  "contributes": {
    "configuration": {
      "title": "Dependency Explorer",
      "properties": {
        "dependencyExplorer.alwaysLatestPackages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Packages to **prefer the latest published version** for during the two bulk operations (this has no effect on updating a single package by hand):\n\n- **Fix All Vulnerabilities** — a listed package targets its **latest** version instead of the smallest safe bump, *as long as that latest version is itself non-vulnerable*. If it isn't, the package quietly falls back to the nearest safe version, so it never lands on a known-vulnerable version.\n- **Update All Packages to Latest** — a listed package is tagged `★ prefer-latest` in the confirmation list.\n\nThe bulk operations otherwise **skip sub-dependencies entirely** (they only act on direct dependencies, to stay fast). Flagging a transitive package here is how you **opt it back into the bulk runs** while still skipping the rest of the transitive tree.\n\nNames are matched case-insensitively, and `*` is a wildcard (e.g. `@myorg/*` matches every package in that scope). Add a package quickly with **Prefer Latest Version** in a dependency's right-click menu — which flips to **Remove from Prefer-Latest List** once it's on the list."
        },
        "dependencyExplorer.neverUpdatePackages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Packages to **hold back from both bulk operations** — they are skipped entirely by **Fix All Vulnerabilities** *and* **Update All Packages to Latest**, and listed afterwards as held back so you know they were left untouched.\n\n⚠️ A held-back package is skipped even when it is vulnerable, so it will stay on a known-vulnerable version until you update it by hand.\n\nUpdating a single package by hand still works — you'll just get an *update anyway?* confirmation first. If a package is on **both** this list and the prefer-latest list, never-update wins during bulk operations.\n\nNames are matched case-insensitively, and `*` is a wildcard (e.g. `@myorg/*` matches every package in that scope). Add a package quickly with **Never Update This Package** in a dependency's right-click menu — which flips to **Remove from Never-Update List** once it's on the list."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dependencyExplorer",
          "title": "Dependencies",
          "icon": "media/dependencies.svg"
        }
      ]
    },
    "views": {
      "dependencyExplorer": [
        {
          "id": "dependencyExplorer.tree",
          "name": "Dependencies",
          "icon": "media/dependencies.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "dependencyExplorer.tree",
        "contents": "No npm, pnpm or NuGet projects found in this workspace.\nnpm/pnpm projects need a package-lock.json or pnpm-lock.yaml (run npm install / pnpm install).\nNuGet projects need obj/project.assets.json (run dotnet restore).\n[Refresh](command:dependencyExplorer.refresh)"
      }
    ],
    "commands": [
      {
        "command": "dependencyExplorer.refresh",
        "title": "Refresh",
        "category": "Dependency Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "dependencyExplorer.fixAcrossProjects",
        "title": "Update Package Across All Projects…",
        "category": "Dependency Explorer",
        "icon": "$(replace-all)"
      },
      {
        "command": "dependencyExplorer.fixAllVulnerabilities",
        "title": "Fix All Vulnerabilities…",
        "category": "Dependency Explorer",
        "icon": "$(shield)"
      },
      {
        "command": "dependencyExplorer.fixProjectVulnerabilities",
        "title": "Fix Vulnerabilities in This Project…",
        "category": "Dependency Explorer",
        "icon": "$(shield)"
      },
      {
        "command": "dependencyExplorer.updateAllToLatest",
        "title": "Update All Packages to Latest…",
        "category": "Dependency Explorer",
        "icon": "$(arrow-circle-up)"
      },
      {
        "command": "dependencyExplorer.updateProjectToLatest",
        "title": "Update All Packages in This Project to Latest…",
        "category": "Dependency Explorer",
        "icon": "$(arrow-circle-up)"
      },
      {
        "command": "dependencyExplorer.bumpAspire",
        "title": "Bump .NET & Aspire Versions…",
        "category": "Dependency Explorer",
        "icon": "$(rocket)"
      },
      {
        "command": "dependencyExplorer.bumpProjectAspire",
        "title": "Bump .NET & Aspire Versions…",
        "category": "Dependency Explorer",
        "icon": "$(rocket)"
      },
      {
        "command": "dependencyExplorer.bumpDotnet",
        "title": "Bump .NET Version…",
        "category": "Dependency Explorer",
        "icon": "$(versions)"
      },
      {
        "command": "dependencyExplorer.bumpProjectDotnet",
        "title": "Bump .NET Version…",
        "category": "Dependency Explorer",
        "icon": "$(versions)"
      },
      {
        "command": "dependencyExplorer.addToAlwaysLatest",
        "title": "Prefer Latest Version",
        "category": "Dependency Explorer",
        "icon": "$(star)"
      },
      {
        "command": "dependencyExplorer.addToNeverUpdate",
        "title": "Never Update This Package",
        "category": "Dependency Explorer",
        "icon": "$(circle-slash)"
      },
      {
        "command": "dependencyExplorer.removeFromAlwaysLatest",
        "title": "Remove from Prefer-Latest List",
        "category": "Dependency Explorer",
        "icon": "$(star-full)"
      },
      {
        "command": "dependencyExplorer.removeFromNeverUpdate",
        "title": "Remove from Never-Update List",
        "category": "Dependency Explorer",
        "icon": "$(circle-slash)"
      },
      {
        "command": "dependencyExplorer.updateDependency",
        "title": "Update Version…",
        "category": "Dependency Explorer",
        "icon": "$(arrow-up)"
      },
      {
        "command": "dependencyExplorer.overrideDependency",
        "title": "Override / Pin Version…",
        "category": "Dependency Explorer",
        "icon": "$(pin)"
      },
      {
        "command": "dependencyExplorer.whyDependency",
        "title": "Why Is This Here?",
        "category": "Dependency Explorer",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "dependencyExplorer.openManifest",
        "title": "Open Manifest",
        "category": "Dependency Explorer",
        "icon": "$(go-to-file)"
      },
      {
        "command": "dependencyExplorer.reinstallProject",
        "title": "Re-install Dependencies",
        "category": "Dependency Explorer",
        "icon": "$(cloud-download)"
      },
      {
        "command": "dependencyExplorer.reinstallAll",
        "title": "Re-install Dependencies in All Projects",
        "category": "Dependency Explorer",
        "icon": "$(cloud-download)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "dependencyExplorer.updateDependency",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.overrideDependency",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.openManifest",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.whyDependency",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.fixProjectVulnerabilities",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.updateProjectToLatest",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.addToAlwaysLatest",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.addToNeverUpdate",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.removeFromAlwaysLatest",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.removeFromNeverUpdate",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.reinstallProject",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.bumpProjectAspire",
          "when": "false"
        },
        {
          "command": "dependencyExplorer.bumpProjectDotnet",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "dependencyExplorer.fixAllVulnerabilities",
          "when": "view == dependencyExplorer.tree",
          "group": "navigation@1"
        },
        {
          "command": "dependencyExplorer.updateAllToLatest",
          "when": "view == dependencyExplorer.tree",
          "group": "navigation@2"
        },
        {
          "command": "dependencyExplorer.bumpAspire",
          "when": "view == dependencyExplorer.tree",
          "group": "navigation@3"
        },
        {
          "command": "dependencyExplorer.fixAcrossProjects",
          "when": "view == dependencyExplorer.tree",
          "group": "navigation@4"
        },
        {
          "command": "dependencyExplorer.reinstallAll",
          "when": "view == dependencyExplorer.tree",
          "group": "navigation@5"
        },
        {
          "command": "dependencyExplorer.refresh",
          "when": "view == dependencyExplorer.tree",
          "group": "navigation@6"
        }
      ],
      "view/item/context": [
        {
          "command": "dependencyExplorer.updateDependency",
          "when": "view == dependencyExplorer.tree && viewItem =~ /^dep:direct/",
          "group": "inline@1"
        },
        {
          "command": "dependencyExplorer.overrideDependency",
          "when": "view == dependencyExplorer.tree && viewItem =~ /^dep:transitive/",
          "group": "inline@1"
        },
        {
          "command": "dependencyExplorer.updateDependency",
          "when": "view == dependencyExplorer.tree && viewItem =~ /^dep:direct/"
        },
        {
          "command": "dependencyExplorer.overrideDependency",
          "when": "view == dependencyExplorer.tree && viewItem =~ /^dep:transitive/"
        },
        {
          "command": "dependencyExplorer.addToAlwaysLatest",
          "when": "view == dependencyExplorer.tree && viewItem =~ /^dep:(direct|transitive)/ && !(viewItem =~ /preferLatest/)",
          "group": "1_modify@2"
        },
        {
          "command": "dependencyExplorer.removeFromAlwaysLatest",
          "when": "view == dependencyExplorer.tree && viewItem =~ /preferLatest/",
          "group": "1_modify@2"
        },
        {
          "command": "dependencyExplorer.whyDependency",
          "when": "view == dependencyExplorer.tree && viewItem =~ /^dep:(direct|transitive)/",
          "group": "0_info@1"
        },
        {
          "command": "dependencyExplorer.addToNeverUpdate",
          "when": "view == dependencyExplorer.tree && viewItem =~ /^dep:(direct|transitive)/ && !(viewItem =~ /neverUpdate/)",
          "group": "1_modify@3"
        },
        {
          "command": "dependencyExplorer.removeFromNeverUpdate",
          "when": "view == dependencyExplorer.tree && viewItem =~ /neverUpdate/",
          "group": "1_modify@3"
        },
        {
          "command": "dependencyExplorer.fixProjectVulnerabilities",
          "when": "view == dependencyExplorer.tree && viewItem =~ /^project/",
          "group": "inline@1"
        },
        {
          "command": "dependencyExplorer.fixProjectVulnerabilities",
          "when": "view == dependencyExplorer.tree && viewItem =~ /^project/"
        },
        {
          "command": "dependencyExplorer.updateProjectToLatest",
          "when": "view == dependencyExplorer.tree && viewItem =~ /^project/"
        },
        {
          "command": "dependencyExplorer.bumpProjectAspire",
          "when": "view == dependencyExplorer.tree && viewItem == project.nuget",
          "group": "1_modify@1"
        },
        {
          "command": "dependencyExplorer.bumpProjectDotnet",
          "when": "view == dependencyExplorer.tree && viewItem == project.nuget",
          "group": "1_modify@2"
        },
        {
          "command": "dependencyExplorer.reinstallProject",
          "when": "view == dependencyExplorer.tree && viewItem =~ /^project/"
        },
        {
          "command": "dependencyExplorer.openManifest",
          "when": "view == dependencyExplorer.tree && viewItem =~ /^project/"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "check-types": "tsc --noEmit -p ./",
    "bundle": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --main-fields=module,main --minify",
    "bundle:watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --main-fields=module,main --sourcemap --watch",
    "test": "npm run compile && node --test \"test/**/*.test.mjs\"",
    "vscode:prepublish": "npm run check-types && npm run bundle"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.5.0"
  }
}
